					</div>
				</div>

				<div class="playlist-scroll-container">
					<!-- Thông báo nếu không có phát thanh trong mục chọn -->
					<p id="empty-playlist-msg" class="empty-playlist-msg">
						Không có phát thanh nào thuộc chuyên mục này.
					</p>

					<ul id="playlist">
						{playlist.map((track, index) => {
							// Định dạng số thứ tự dạng hai chữ số (01, 02...)
							const trackNum = String(index + 1).padStart(2, '0');
							// Rút gọn tiêu đề hiển thị trong danh sách phát cho gọn gàng và đẹp
							let displayName = track.title;
							displayName = displayName.replace(/\[\d{2}-\d{2}-\d{4}\]/g, ''); // Xóa [DD-MM-YYYY]
							displayName = displayName.replace(/Phát thanh Minh Huệ:\s*/g, '');
							displayName = displayName.replace(/Phát thanh Minh Huệ\s*\(.*?\):\s*/g, '');
							displayName = displayName.trim();

							return (
								<li 
									data-url={track.url} 
									data-title={track.title} 
									data-category={track.category} 
									class={index === 0 ? "active" : ""}
								>
									<span class="track-number">{trackNum}</span>
									<span class="track-name" title={track.title}>{displayName}</span>
								</li>
							);
						})}
					</ul>
				</div>
