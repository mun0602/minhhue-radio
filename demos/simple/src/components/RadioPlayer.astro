							<li class="sub-category-nav-item" data-filter="bai-chia-se-co-loi-binh-cua-su-phu">
								<div>
									<a href="/news/category/bai-chia-se-co-loi-binh-cua-su-phu">Bài chia sẻ có lời bình của Sư phụ</a>
								</div>
							</li>
						</ul>
					</div>
				</div>
 
				<div class="playlist-scroll-container" id="playlist-scroll-container">
					<!-- Thông báo nếu không có phát thanh trong mục chọn -->
					<p id="empty-playlist-msg" class="empty-playlist-msg">
						Không có phát thanh nào thuộc chuyên mục này.
					</p>
 
					<!-- Virtual scrolling: chỉ render các item hiển thị -->
					<div id="playlist-virtual-spacer" style="position:relative;">
						<ul id="playlist"></ul>
					</div>
				</div>
				<!-- Truyền dữ liệu playlist qua JSON thay vì render 3441 DOM nodes -->
				<script id="playlist-data" type="application/json" set:html={JSON.stringify(playlist)} />
			</div>
		</div>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const audio = document.getElementById('audio-player') as HTMLAudioElement;
		const currentTrackTitle = document.getElementById('current-track-title');
		const playlistContainer = document.getElementById('playlist');
		const scrollContainer = document.getElementById('playlist-scroll-container');
		const virtualSpacer = document.getElementById('playlist-virtual-spacer');
		const revertButton = document.getElementById('revert-playlist');
		const randomButton = document.getElementById('random-playlist');
		const searchToggleBtn = document.getElementById('search-toggle-btn');
		const searchBarWrapper = document.getElementById('search-bar-wrapper');
		const searchInput = document.getElementById('playlist-search-input') as HTMLInputElement;
		const clearSearchBtn = document.getElementById('clear-search-btn');
		
		const categoriesToggle = document.getElementById('categories-toggle');
		const categoriesDropdown = document.getElementById('categories-dropdown');
		const selectedCategoryText = document.getElementById('selected-category-text');
		const emptyPlaylistMsg = document.getElementById('empty-playlist-msg');
		const dropdownItems = categoriesDropdown ? Array.from(categoriesDropdown.querySelectorAll('.sub-category-nav-item')) : [];

		const playBtn = document.getElementById('custom-play-btn');
		const playIcon = document.getElementById('play-icon');
		const pauseIcon = document.getElementById('pause-icon');
		const seekSlider = document.getElementById('custom-seek-slider') as HTMLInputElement;
		const timeCurrent = document.getElementById('custom-time-current');
		const timeDuration = document.getElementById('custom-time-duration');
		const speedBtn = document.getElementById('custom-speed-btn');
		const speedText = document.getElementById('speed-text');
		const rewindBtn = document.getElementById('custom-rewind-btn');
		const forwardBtn = document.getElementById('custom-forward-btn');
		const statusDot = document.getElementById('player-status-dot');
		const statusText = document.getElementById('player-status-text');

		const sleepBtn = document.getElementById('custom-sleep-btn');
		const sleepBtnText = document.getElementById('sleep-btn-text');
		const sleepDropdown = document.getElementById('sleep-timer-dropdown');
		const sleepItems = sleepDropdown ? Array.from(sleepDropdown.querySelectorAll('li')) : [];

		// Mobile bottom bar elements
		const mobilePlayBtn = document.getElementById('mobile-play-btn');
		const mobilePlayIcon = mobilePlayBtn?.querySelector('.mobile-play-icon');
		const mobilePauseIcon = mobilePlayBtn?.querySelector('.mobile-pause-icon');
		const mobileTrackTitle = document.getElementById('mobile-track-title');
		const mobileTimeCurrent = document.getElementById('mobile-time-current');
		const mobileTimeDuration = document.getElementById('mobile-time-duration');
		const mobileSleepBtn = document.getElementById('mobile-sleep-btn');
		const mobileSleepBtnText = document.getElementById('mobile-sleep-btn-text');
		const mobileSleepDropdown = document.getElementById('mobile-sleep-dropdown');
		const mobileSleepItems = mobileSleepDropdown ? Array.from(mobileSleepDropdown.querySelectorAll('li')) : [];
		const mobileSeekSlider = document.getElementById('mobile-seek-slider') as HTMLInputElement;

		if (!audio || !currentTrackTitle || !playlistContainer || !scrollContainer || !virtualSpacer) return;

		// ===== FIRST TIME COPYRIGHT NOTIFICATION =====
		const copyrightModal = document.getElementById('copyright-modal');
		const modalContinueBtn = document.getElementById('modal-continue-btn');

		if (copyrightModal) {
			const hasAccepted = localStorage.getItem('minhhue_copyright_accepted');
			if (!hasAccepted) {
				copyrightModal.style.display = 'flex';
			}
			
			if (modalContinueBtn) {
				modalContinueBtn.addEventListener('click', () => {
					localStorage.setItem('minhhue_copyright_accepted', 'true');
					copyrightModal.classList.add('fade-out');
					setTimeout(() => {
						copyrightModal.style.display = 'none';
						copyrightModal.classList.remove('fade-out');
					}, 300);
				});
			}
		}

		// ===== VIRTUAL SCROLLING ENGINE =====
		const ITEM_HEIGHT = 52; // px per playlist item (padding + gap)
		const BUFFER = 10; // extra items above/below viewport
		const allTracks: {title:string; url:string; category:string}[] = JSON.parse(
			document.getElementById('playlist-data')!.textContent!
		);
		let visibleTracks = allTracks.map((t, i) => ({...t, originalIndex: i}));
		let activeTrackUrl = allTracks[0]?.url || '';

		// Đọc/ghi nhận danh sách các bài đã nghe từ localStorage
		let listenedTracks: string[] = [];
		try {
			const savedListened = localStorage.getItem('minhhue_listened_tracks');
			if (savedListened) listenedTracks = JSON.parse(savedListened);
		} catch (e) {}

		function markTrackAsListened(url: string) {
			if (!listenedTracks.includes(url)) {
				listenedTracks.push(url);
				localStorage.setItem('minhhue_listened_tracks', JSON.stringify(listenedTracks));
				lastRenderStart = -1; // buộc render lại
				renderVirtualList();
			}
		}

		function cleanTitle(title: string) {
			return title.replace(/\[\d{2}-\d{2}-\d{4}\]/g, '')
				.replace(/Phát thanh Minh Huệ:\s*/g, '')
				.replace(/Phát thanh Minh Huệ\s*\(.*?\):\s*/g, '')
				.trim();
		}

		let lastRenderStart = -1, lastRenderEnd = -1;
		function renderVirtualList() {
			const scrollTop = scrollContainer.scrollTop;
			const viewHeight = scrollContainer.clientHeight;
			const totalHeight = visibleTracks.length * ITEM_HEIGHT;
			virtualSpacer.style.height = totalHeight + 'px';

			const startIdx = Math.max(0, Math.floor(scrollTop / ITEM_HEIGHT) - BUFFER);
			const endIdx = Math.min(visibleTracks.length, Math.ceil((scrollTop + viewHeight) / ITEM_HEIGHT) + BUFFER);

			if (startIdx === lastRenderStart && endIdx === lastRenderEnd) return;
			lastRenderStart = startIdx;
			lastRenderEnd = endIdx;

			let html = '';
			for (let i = startIdx; i < endIdx; i++) {
				const t = visibleTracks[i];
				const num = String(t.originalIndex + 1).padStart(2, '0');
				const isActive = t.url === activeTrackUrl;
				const isListened = listenedTracks.includes(t.url);
				const cssClass = `${isActive ? 'active' : ''} ${isListened ? 'listened' : ''}`.trim();
				html += `<li data-idx="${i}" style="position:absolute;top:${i * ITEM_HEIGHT}px;left:0;right:0;height:${ITEM_HEIGHT}px;" class="${cssClass}"><span class="track-number">${num}</span><span class="track-name" title="${t.title.replace(/"/g, '&quot;')}">${cleanTitle(t.title)}</span></li>`;
			}
			playlistContainer.innerHTML = html;
		}

		let scrollRaf = 0;
		scrollContainer.addEventListener('scroll', () => {
			if (!scrollRaf) scrollRaf = requestAnimationFrame(() => { renderVirtualList(); scrollRaf = 0; });
		}, {passive: true});

		renderVirtualList();

		function scrollToTrack(trackUrl: string) {
			const idx = visibleTracks.findIndex(t => t.url === trackUrl);
			if (idx >= 0) {
				const targetTop = idx * ITEM_HEIGHT - scrollContainer.clientHeight / 2 + ITEM_HEIGHT / 2;
				scrollContainer.scrollTop = Math.max(0, targetTop);
			}
		}

		// Playlist click delegation (virtual items)
		playlistContainer.addEventListener('click', (e) => {
			const li = (e.target as HTMLElement).closest('li');
			if (!li) return;
			const idx = parseInt(li.getAttribute('data-idx')!, 10);
			if (isNaN(idx)) return;
			playTrackByIndex(idx);
		});

		// ===== SPEED CONTROL =====
		const speeds = [1.0, 1.25, 1.5, 2.0, 0.75];
		let currentSpeedIndex = 0;

		if (speedBtn && speedText) {
			speedBtn.addEventListener('click', () => {
				currentSpeedIndex = (currentSpeedIndex + 1) % speeds.length;
				audio.playbackRate = speeds[currentSpeedIndex];
				speedText.textContent = `${speeds[currentSpeedIndex]}x`;
			});
		}

		// ===== SLEEP TIMER =====
		let sleepTimerInterval: any = null;
		let sleepTimeRemaining = 0;
		let stopAtTrackEnd = false;

		if (sleepBtn && sleepDropdown) {
			sleepBtn.addEventListener('click', (e) => { e.stopPropagation(); sleepDropdown.style.display = sleepDropdown.style.display === 'block' ? 'none' : 'block'; });
			document.addEventListener('click', () => { sleepDropdown.style.display = 'none'; });
			sleepItems.forEach((item) => {
				item.addEventListener('click', (e) => {
					e.stopPropagation();
					const val = item.getAttribute('data-minutes');
					sleepDropdown.style.display = 'none';
					if (sleepTimerInterval) { clearInterval(sleepTimerInterval); sleepTimerInterval = null; }
					stopAtTrackEnd = false;
					if (val === '0') {
						sleepTimeRemaining = 0;
						if (sleepBtnText) sleepBtnText.textContent = 'Hẹn giờ';
						if (mobileSleepBtnText) mobileSleepBtnText.textContent = 'Hẹn giờ';
						sleepBtn.classList.remove('active-timer');
						mobileSleepBtn?.classList.remove('active-timer');
					} else if (val === 'end') {
						stopAtTrackEnd = true;
						if (sleepBtnText) sleepBtnText.textContent = 'Hết bài';
						if (mobileSleepBtnText) mobileSleepBtnText.textContent = 'Hết bài';
						sleepBtn.classList.add('active-timer');
						mobileSleepBtn?.classList.add('active-timer');
					} else if (val) {
						sleepTimeRemaining = parseInt(val, 10) * 60;
						sleepBtn.classList.add('active-timer');
						mobileSleepBtn?.classList.add('active-timer');
						startSleepTimer();
					}
				});
			});
		}

		// Mobile sleep timer setup
		if (mobileSleepBtn && mobileSleepDropdown) {
			mobileSleepBtn.addEventListener('click', (e) => {
				e.stopPropagation();
				mobileSleepDropdown.style.display = mobileSleepDropdown.style.display === 'block' ? 'none' : 'block';
			});
			document.addEventListener('click', () => {
				if (mobileSleepDropdown) mobileSleepDropdown.style.display = 'none';
			});
			mobileSleepItems.forEach((item) => {
				item.addEventListener('click', (e) => {
					e.stopPropagation();
					const val = item.getAttribute('data-minutes');
					if (mobileSleepDropdown) mobileSleepDropdown.style.display = 'none';
					if (sleepTimerInterval) { clearInterval(sleepTimerInterval); sleepTimerInterval = null; }
					stopAtTrackEnd = false;
					
					if (val === '0') {
						sleepTimeRemaining = 0;
						if (sleepBtnText) sleepBtnText.textContent = 'Hẹn giờ';
						if (mobileSleepBtnText) mobileSleepBtnText.textContent = 'Hẹn giờ';
						sleepBtn?.classList.remove('active-timer');
						mobileSleepBtn.classList.remove('active-timer');
					} else if (val === 'end') {
						stopAtTrackEnd = true;
						if (sleepBtnText) sleepBtnText.textContent = 'Hết bài';
						if (mobileSleepBtnText) mobileSleepBtnText.textContent = 'Hết bài';
						sleepBtn?.classList.add('active-timer');
						mobileSleepBtn.classList.add('active-timer');
					} else if (val) {
						sleepTimeRemaining = parseInt(val, 10) * 60;
						sleepBtn?.classList.add('active-timer');
						mobileSleepBtn.classList.add('active-timer');
						startSleepTimer();
					}
				});
			});
		}

		function startSleepTimer() {
			updateSleepButtonText();
			sleepTimerInterval = setInterval(() => {
				if (sleepTimeRemaining <= 0) { clearInterval(sleepTimerInterval); sleepTimerInterval = null; triggerSleepStop(); }
				else { sleepTimeRemaining--; updateSleepButtonText(); }
			}, 1000);
		}
		function updateSleepButtonText() {
			const timeStr = `${String(Math.floor(sleepTimeRemaining / 60)).padStart(2, '0')}:${String(sleepTimeRemaining % 60).padStart(2, '0')}`;
			if (sleepBtnText) sleepBtnText.textContent = timeStr;
			if (mobileSleepBtnText) mobileSleepBtnText.textContent = timeStr;
		}
		function triggerSleepStop() {
			let vol = audio.volume;
			const fade = setInterval(() => {
				if (vol > 0.05) { vol -= 0.05; audio.volume = Math.max(0, vol); }
				else {
					clearInterval(fade);
					audio.pause();
					audio.volume = 1.0;
					if (sleepBtnText) sleepBtnText.textContent = 'Hẹn giờ';
					if (mobileSleepBtnText) mobileSleepBtnText.textContent = 'Hẹn giờ';
					sleepBtn?.classList.remove('active-timer');
					mobileSleepBtn?.classList.remove('active-timer');
				}
			}, 100);
		}

		// Tua lùi 10s và tua đi 30s
		if (rewindBtn) {
			rewindBtn.addEventListener('click', () => {
				try {
					audio.currentTime = Math.max(0, audio.currentTime - 10);
				} catch (e) {
					console.warn("Lỗi tua lùi (đặc thù iOS):", e);
				}
			});
		}
		if (forwardBtn) {
			forwardBtn.addEventListener('click', () => {
				try {
					audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 30);
				} catch (e) {
					console.warn("Lỗi tua đi (đặc thù iOS):", e);
				}
			});
		}

		const formatTime = (secs: number) => isNaN(secs) ? "00:00" : `${String(Math.floor(secs / 60)).padStart(2, '0')}:${String(Math.floor(secs % 60)).padStart(2, '0')}`;

		const updatePlayState = (isPlaying: boolean) => {
			if (!playIcon || !pauseIcon || !statusDot || !statusText) return;
			playIcon.style.display = isPlaying ? 'none' : 'block';
			pauseIcon.style.display = isPlaying ? 'block' : 'none';
			statusDot.classList.toggle('playing', isPlaying);
			statusText.textContent = isPlaying ? 'Đang phát' : 'Đang dừng';
			playBtn?.classList.toggle('playing', isPlaying);
			// Sync mobile bar
			if (mobilePlayIcon) (mobilePlayIcon as HTMLElement).style.display = isPlaying ? 'none' : 'block';
			if (mobilePauseIcon) (mobilePauseIcon as HTMLElement).style.display = isPlaying ? 'block' : 'none';
		};

		if (playBtn) playBtn.addEventListener('click', () => { audio.paused ? audio.play().catch(() => {}) : audio.pause(); });
		if (mobilePlayBtn) mobilePlayBtn.addEventListener('click', () => { audio.paused ? audio.play().catch(() => {}) : audio.pause(); });
		if (mobileSleepBtn) mobileSleepBtn.addEventListener('click', () => { sleepBtn?.click(); });
		audio.addEventListener('play', () => updatePlayState(true));
		audio.addEventListener('pause', () => updatePlayState(false));

		let isDraggingSlider = false;
		audio.addEventListener('timeupdate', () => {
			if (seekSlider && !isDraggingSlider) {
				const pct = audio.duration > 0 ? (audio.currentTime / audio.duration) * 100 : 0;
				seekSlider.value = String(pct);
				seekSlider.style.background = `linear-gradient(to right, var(--color-accent) ${pct}%, var(--color-border) ${pct}%)`;
			}
			if (mobileSeekSlider && !isDraggingSlider) {
				const pct = audio.duration > 0 ? (audio.currentTime / audio.duration) * 100 : 0;
				mobileSeekSlider.value = String(pct);
				mobileSeekSlider.style.background = `linear-gradient(to right, var(--color-accent) ${pct}%, var(--color-border) ${pct}%)`;
			}
			if (timeCurrent) timeCurrent.textContent = formatTime(audio.currentTime);
			if (mobileTimeCurrent) mobileTimeCurrent.textContent = formatTime(audio.currentTime);
		});
		audio.addEventListener('loadedmetadata', () => {
			if (timeDuration) timeDuration.textContent = formatTime(audio.duration);
			if (mobileTimeDuration) mobileTimeDuration.textContent = formatTime(audio.duration);
			if (seekSlider) seekSlider.style.background = `linear-gradient(to right, var(--color-accent) 0%, var(--color-border) 0%)`;
			if (mobileSeekSlider) mobileSeekSlider.style.background = `linear-gradient(to right, var(--color-accent) 0%, var(--color-border) 0%)`;
		});
		if (seekSlider) {
			seekSlider.addEventListener('input', () => {
				isDraggingSlider = true;
				if (timeCurrent) {
					const duration = audio.duration || 0;
					const targetTime = (parseFloat(seekSlider.value) / 100) * duration;
					timeCurrent.textContent = formatTime(targetTime);
				}
			});

			seekSlider.addEventListener('change', () => {
				isDraggingSlider = false;
				const duration = audio.duration || 0;
				try {
					audio.currentTime = (parseFloat(seekSlider.value) / 100) * duration;
				} catch (e) {
					console.warn("Lỗi kéo thanh trượt (đặc thù iOS):", e);
				}
			});
		}
		if (mobileSeekSlider) {
			mobileSeekSlider.addEventListener('input', () => {
				isDraggingSlider = true;
				if (mobileTimeCurrent) {
					const duration = audio.duration || 0;
					const targetTime = (parseFloat(mobileSeekSlider.value) / 100) * duration;
					mobileTimeCurrent.textContent = formatTime(targetTime);
				}
			});

			mobileSeekSlider.addEventListener('change', () => {
				isDraggingSlider = false;
				const duration = audio.duration || 0;
				try {
					audio.currentTime = (parseFloat(mobileSeekSlider.value) / 100) * duration;
				} catch (e) {
					console.warn("Lỗi kéo thanh trượt di động (đặc thù iOS):", e);
				}
			});
		}

		// ===== PLAY TRACK BY INDEX (virtual) =====
		function playTrackByIndex(idx: number) {
			const t = visibleTracks[idx];
			if (!t) return;
			audio.src = `/api/audio-proxy?url=${encodeURIComponent(t.url)}`;
			audio.playbackRate = speeds[currentSpeedIndex];
			
			// Gọi load() và play() để vượt qua cơ chế chặn tự động phát của iOS/Safari
			audio.load();
			const playPromise = audio.play();
			if (playPromise !== undefined) {
				playPromise.catch(error => {
					console.warn("Autoplay bị chặn hoặc thất bại trên thiết bị di động:", error);
				});
			}
			
			activeTrackUrl = t.url;
			markTrackAsListened(t.url); // Đánh dấu đã nghe bài này
			currentTrackTitle!.textContent = t.title;
			if (mobileTrackTitle) mobileTrackTitle.textContent = cleanTitle(t.title);
			lastRenderStart = -1; // force re-render
			renderVirtualList();
		}

		// ===== RESTORE STATE =====
		const savedStateStr = localStorage.getItem('minhhue_radio_state');
		if (savedStateStr) {
			try {
				const s = JSON.parse(savedStateStr);
				if (s.url && s.title) {
					audio.src = `/api/audio-proxy?url=${encodeURIComponent(s.url)}`;
					currentTrackTitle.textContent = s.title;
					activeTrackUrl = s.url;
					markTrackAsListened(s.url); // Đánh dấu đã nghe bài khôi phục từ trước
					audio.playbackRate = speeds[currentSpeedIndex];

					// Khôi phục giao diện hiển thị thời gian ngay lập tức để người dùng thấy trạng thái cũ
					if (s.time) {
						if (timeCurrent) timeCurrent.textContent = formatTime(s.time);
						if (mobileTimeCurrent) mobileTimeCurrent.textContent = formatTime(s.time);
						if (s.duration) {
							if (timeDuration) timeDuration.textContent = formatTime(s.duration);
							if (mobileTimeDuration) mobileTimeDuration.textContent = formatTime(s.duration);
							const pct = (s.time / s.duration) * 100;
							if (seekSlider) {
								seekSlider.value = String(pct);
								seekSlider.style.background = `linear-gradient(to right, var(--color-accent) ${pct}%, var(--color-border) ${pct}%)`;
							}
							if (mobileSeekSlider) {
								mobileSeekSlider.value = String(pct);
								mobileSeekSlider.style.background = `linear-gradient(to right, var(--color-accent) ${pct}%, var(--color-border) ${pct}%)`;
							}
						}
					}

					// Khôi phục thời gian phát thực tế trên iOS/Safari
					let hasSetTime = false;
					const setSavedTime = () => {
						if (hasSetTime) return;
						try {
							const targetDuration = audio.duration || s.duration;
							if (s.time && isFinite(targetDuration) && targetDuration > 0) {
								audio.currentTime = Math.min(s.time, targetDuration);
								hasSetTime = true;
								
								// Gỡ bỏ lắng nghe sau khi đã thiết lập thời gian thành công
								audio.removeEventListener('loadedmetadata', setSavedTime);
								audio.removeEventListener('loadeddata', setSavedTime);
								audio.removeEventListener('canplay', setSavedTime);
								audio.removeEventListener('play', setSavedTime);
							}
						} catch (e) {
							console.warn("Không thể khôi phục currentTime (đặc thù iOS):", e);
						}
						if (timeDuration && isFinite(audio.duration) && audio.duration > 0) {
							timeDuration.textContent = formatTime(audio.duration);
						}
						if (mobileTimeDuration && isFinite(audio.duration) && audio.duration > 0) {
							mobileTimeDuration.textContent = formatTime(audio.duration);
						}
					};
					audio.addEventListener('loadedmetadata', setSavedTime);
					audio.addEventListener('loadeddata', setSavedTime);
					audio.addEventListener('canplay', setSavedTime);
					audio.addEventListener('play', setSavedTime);

					lastRenderStart = -1;
					renderVirtualList();
					setTimeout(() => scrollToTrack(s.url), 300);
				}
			} catch (e) {}
		}

		// ===== SAVE STATE (throttled) =====
		let lastSaveTime = 0;
		audio.addEventListener('timeupdate', () => {
			if (Date.now() - lastSaveTime > 5000) {
				lastSaveTime = Date.now();
				const t = visibleTracks.find(t => t.url === activeTrackUrl);
				if (t) {
					localStorage.setItem('minhhue_radio_state', JSON.stringify({
						url: t.url,
						title: t.title,
						time: audio.currentTime,
						duration: isFinite(audio.duration) && audio.duration > 0 ? audio.duration : null
					}));
				}
			}
		});

		// ===== CATEGORY FILTER =====
		let currentFilter = 'all';
		function applyFilter(filter: string) {
			currentFilter = filter;
			if (filter === 'all') {
				visibleTracks = allTracks.map((t, i) => ({...t, originalIndex: i}));
			} else {
				visibleTracks = allTracks.reduce((acc, t, i) => {
					let match = t.category === filter;
					if (!match && filter === 'ngay-phap-luan-dai-phap-the-gioi-radio') match = t.category?.startsWith('ngay-phap-luan-dai-phap-the-gioi');
					if (!match && filter === 'phap-hoi-trung-quoc-radio') match = t.category?.startsWith('phap-hoi-trung-quoc');
					if (match) acc.push({...t, originalIndex: i});
					return acc;
				}, [] as typeof visibleTracks);
			}
			if (emptyPlaylistMsg) emptyPlaylistMsg.style.display = visibleTracks.length === 0 ? 'block' : 'none';
			scrollContainer.scrollTop = 0;
			lastRenderStart = -1;
			renderVirtualList();
		}

		// URL filter param hoặc khôi phục chuyên mục đã lưu từ localStorage
		const filterParam = new URLSearchParams(window.location.search).get('filter') || localStorage.getItem('minhhue_selected_category');
		if (filterParam) {
			const targetItem = dropdownItems.find(item => item.getAttribute('data-filter') === filterParam);
			if (targetItem) setTimeout(() => (targetItem as HTMLElement).click(), 100);
		}

		if (categoriesToggle && categoriesDropdown) {
			categoriesToggle.addEventListener('click', (e) => { e.stopPropagation(); categoriesDropdown.style.display = categoriesDropdown.style.display === 'block' ? 'none' : 'block'; categoriesToggle.classList.toggle('open'); });
			document.addEventListener('click', () => { categoriesDropdown.style.display = 'none'; categoriesToggle.classList.remove('open'); });
			dropdownItems.forEach((item) => {
				const link = item.querySelector('a');
				if (link) link.addEventListener('click', (e) => e.preventDefault());
				item.addEventListener('click', function(e) {
					e.stopPropagation();
					const filter = item.getAttribute('data-filter') || 'all';
					dropdownItems.forEach(i => i.classList.remove('active-category'));
					item.classList.add('active-category');
					if (selectedCategoryText) selectedCategoryText.textContent = item.querySelector('a')?.textContent || '';
					applyFilter(filter);
					localStorage.setItem('minhhue_selected_category', filter);
					categoriesDropdown.style.display = 'none';
					categoriesToggle.classList.remove('open');
				});
			});
		}

		// ===== REVERT, RANDOM & SEARCH =====
		let isRandomMode = false;
		if (revertButton) {
			revertButton.addEventListener('click', () => {
				visibleTracks.reverse();
				scrollContainer.scrollTop = 0;
				lastRenderStart = -1;
				renderVirtualList();
				
				// Kích hoạt hoạt ảnh xoay 180 độ khi bấm đảo thứ tự
				revertButton.classList.toggle('rotated');
			});
		}

		if (searchToggleBtn && searchBarWrapper && searchInput) {
			searchToggleBtn.addEventListener('click', () => {
				const isHidden = searchBarWrapper.style.display === 'none';
				searchBarWrapper.style.display = isHidden ? 'block' : 'none';
				searchToggleBtn.classList.toggle('active-mode', isHidden);
				if (isHidden) {
					searchInput.focus();
				} else {
					searchInput.value = '';
					if (clearSearchBtn) clearSearchBtn.style.display = 'none';
					applyFilter(currentFilter); // khôi phục danh sách
				}
			});
		}

		function removeTones(str: string) {
			return str
				.normalize("NFD")
				.replace(/[\u0300-\u036f]/g, "")
				.replace(/đ/g, "d")
				.replace(/Đ/g, "D");
		}

		if (searchInput) {
			searchInput.addEventListener('input', () => {
				const val = removeTones(searchInput.value.toLowerCase().trim());
				if (clearSearchBtn) clearSearchBtn.style.display = val ? 'block' : 'none';
				
				let baseTracks = allTracks.map((t, i) => ({...t, originalIndex: i}));
				if (currentFilter !== 'all') {
					baseTracks = baseTracks.filter(t => {
						let match = t.category === currentFilter;
						if (!match && currentFilter === 'ngay-phap-luan-dai-phap-the-gioi-radio') match = t.category?.startsWith('ngay-phap-luan-dai-phap-the-gioi');
						if (!match && currentFilter === 'phap-hoi-trung-quoc-radio') match = t.category?.startsWith('phap-hoi-trung-quoc');
						return match;
					});
				}

				if (val) {
					visibleTracks = baseTracks.filter(t => 
						removeTones(t.title.toLowerCase()).includes(val)
					);
				} else {
					visibleTracks = baseTracks;
				}

				if (emptyPlaylistMsg) emptyPlaylistMsg.style.display = visibleTracks.length === 0 ? 'block' : 'none';
				scrollContainer.scrollTop = 0;
				lastRenderStart = -1;
				renderVirtualList();
			});
		}

		if (clearSearchBtn && searchInput) {
			clearSearchBtn.addEventListener('click', () => {
				searchInput.value = '';
				clearSearchBtn.style.display = 'none';
				searchInput.dispatchEvent(new Event('input'));
				searchInput.focus();
			});
		}
		if (randomButton) {
			randomButton.addEventListener('click', () => {
				isRandomMode = !isRandomMode;
				randomButton.classList.toggle('active-mode', isRandomMode);
				if (isRandomMode && visibleTracks.length > 0) {
					playTrackByIndex(Math.floor(Math.random() * visibleTracks.length));
				}
			});
		}

		// ===== AUTO-NEXT =====
		audio.addEventListener('ended', () => {
			if (stopAtTrackEnd) {
				audio.pause();
				stopAtTrackEnd = false;
				if (sleepBtnText) sleepBtnText.textContent = 'Hẹn giờ';
				if (mobileSleepBtnText) mobileSleepBtnText.textContent = 'Hẹn giờ';
				sleepBtn?.classList.remove('active-timer');
				mobileSleepBtn?.classList.remove('active-timer');
				return;
			}
			if (isRandomMode) {
				playTrackByIndex(Math.floor(Math.random() * visibleTracks.length));
				return;
			}
			const idx = visibleTracks.findIndex(t => t.url === activeTrackUrl);
			if (idx >= 0 && idx < visibleTracks.length - 1) {
				playTrackByIndex(idx + 1);
			} else if (visibleTracks.length > 0) {
				playTrackByIndex(0);
			}
		});

		// ===== HEADER MENU LINKS =====
		document.querySelectorAll('.dropdown-menu-item').forEach(link => {
			link.addEventListener('click', (e) => {
				if (['/', '', '/index.html'].includes(window.location.pathname)) {
					e.preventDefault();
					const url = new URL((link as HTMLAnchorElement).href);
					const filterVal = url.searchParams.get('filter');
					if (filterVal) {
						window.history.pushState({}, '', url.pathname + url.search);
						const targetItem = dropdownItems.find(item => item.getAttribute('data-filter') === filterVal);
						if (targetItem) (targetItem as HTMLElement).click();
					}
				}
			});
		});
	});
</script>
