---
// Component Trình phát Radio Minh Huệ siêu cao cấp "Emdash Prime"
import fs from "node:fs";
import path from "node:path";

// Đọc danh sách phát từ file JSON đã cào
const filePath = path.resolve("./radio-playlist.json");
const playlist = fs.existsSync(filePath)
	? JSON.parse(fs.readFileSync(filePath, "utf-8"))
	: [];

// Bài hát đầu tiên làm mặc định
const defaultTrack = playlist.length > 0 ? playlist[0] : {
	title: "Phát thanh Minh Huệ: Trừ bỏ chấp trước vào điện thoại – Tìm về trạng thái tu luyện như thuở đầu (Số 3)",
	url: "https://vi.minghui.org/radio/20250926-TDTH.mp3",
	category: "tru-bo-chap-truoc-vao-dien-thoai"
};
---

<!-- Thư viện Plyr.css từ CDN (chỉ nạp cho component này) -->
<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />

<div class="emdash-radio-card">
	{/* Hiệu ứng phát quang nhẹ ở viền thẻ */}
	<div class="radio-glow-border"></div>

	<div class="radio-grid-layout-premium">
		{/* Panel bên trái: Trình phát nhạc chính */}
		<div class="radio-left-panel-premium">
			{/* Tiêu đề & Trạng thái phát */}
			<header class="radio-header">
				<div class="radio-live-tag">
					<span class="live-pulse"></span>
					RADIO
				</div>
				<h3 class="radio-main-title">Phát Thanh Minh Huệ</h3>
			</header>

			{/* Giao diện bài đang phát hiện tại */}
			<div class="now-playing-box">
				<span class="now-playing-label">Đang phát:</span>
				<h4 id="current-track-title" class="current-track-title">
					{defaultTrack.title}
				</h4>
			</div>

			{/* Trình phát Audio của Plyr */}
			<div class="plyr-wrapper">
				<audio id="audio-player" controls>
					<source src={`/api/audio-proxy?url=${encodeURIComponent(defaultTrack.url)}`} type="audio/mpeg" />
					Trình duyệt của bạn không hỗ trợ phát âm thanh trực tiếp.
				</audio>
			</div>
		</div>

		{/* Panel bên phải: Danh sách phát */}
		<div class="radio-right-panel-premium">
			<div class="playlist-section">
				<div class="playlist-header">
					<h4 class="playlist-title">Danh Sách Phát Mới Nhất</h4>
					<div class="playlist-actions">
						<button id="random-playlist" class="action-btn" title="Phát ngẫu nhiên">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 17h10"/><path d="M7 12h10"/><path d="M7 7h10"/></svg>
							Ngẫu nhiên
						</button>
						<button id="revert-playlist" class="action-btn" title="Đảo thứ tự bài">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 16 4 4 4-4"/><path d="M7 20V4"/><path d="m21 8-4-4-4 4"/><path d="M17 4v16"/></svg>
							Đảo thứ tự
						</button>
					</div>
				</div>

				<!-- Thẻ nhúng danh mục đồng bộ chuẩn 100% giao thức Minh Huệ Net -->
				<div class="categories-filter-wrapper">
					<div class="sub-categories-nav-toggle" id="categories-toggle">
						<span id="selected-category-text">Danh sách chuyên mục</span>
						<i class="sub-categories-nav-icon"></i>
					</div>
					
					<div class="sub-categories-nav-items" id="categories-dropdown" style="display: none;">
						<ul>
							<li class="sub-category-nav-item active-category" data-filter="all">
								<div>
									<a href="#">Tất cả phát thanh</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tru-bo-chap-truoc-vao-dien-thoai">
								<div>
									<a href="/news/category/tru-bo-chap-truoc-vao-dien-thoai">Trừ bỏ chấp trước vào điện thoại</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="ngay-phap-luan-dai-phap-the-gioi-radio">
								<div>
									<a href="/news/category/ngay-phap-luan-dai-phap-the-gioi-radio">Ngày Pháp Luân Đại Pháp Thế giới</a>
								</div>
							</li>
