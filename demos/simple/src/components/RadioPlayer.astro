<!-- Nạp Plyr.js động từ CDN và chạy logic xử lý danh sách phát -->
<script is:inline src="https://cdn.plyr.io/3.7.8/plyr.js"></script>

<script>
	// Khai báo kiểu cho Plyr từ CDN để tránh lỗi build TypeScript
	declare const Plyr: any;

	document.addEventListener('DOMContentLoaded', () => {
		// 1. Khởi tạo Plyr
		const player = new Plyr('#audio-player', {
			controls: ['play', 'progress', 'current-time', 'mute', 'volume', 'settings'],
			tooltips: { controls: true, seek: true }
		});

		const audio = document.getElementById('audio-player') as HTMLAudioElement;
		const currentTrackTitle = document.getElementById('current-track-title');
		const playlistContainer = document.getElementById('playlist');
		const revertButton = document.getElementById('revert-playlist');
		const randomButton = document.getElementById('random-playlist');
		
		// Selector cho bộ lọc chuyên mục
		const categoriesToggle = document.getElementById('categories-toggle');
		const categoriesDropdown = document.getElementById('categories-dropdown');
		const selectedCategoryText = document.getElementById('selected-category-text');
		const emptyPlaylistMsg = document.getElementById('empty-playlist-msg');
		const dropdownItems = categoriesDropdown ? Array.from(categoriesDropdown.querySelectorAll('.sub-category-nav-item')) : [];

		if (!audio || !currentTrackTitle || !playlistContainer) return;

		// Khôi phục trạng thái phát nhạc từ localStorage
		const savedStateStr = localStorage.getItem('minhhue_radio_state');
		if (savedStateStr) {
			try {
				const savedState = JSON.parse(savedStateStr);
				if (savedState.url && savedState.title) {
					audio.src = `/api/audio-proxy?url=${encodeURIComponent(savedState.url)}`;
					currentTrackTitle.textContent = savedState.title;
					
					// Đặt lại thời gian khi metadata đã tải xong
					const setSavedTime = () => {
						if (savedState.time) {
							audio.currentTime = savedState.time;
						}
						audio.removeEventListener('loadedmetadata', setSavedTime);
					};
					audio.addEventListener('loadedmetadata', setSavedTime);

					// Đánh dấu active trên danh sách
					const playlistItemsForRestoration = Array.from(playlistContainer.querySelectorAll('li'));
					playlistItemsForRestoration.forEach(i => i.classList.remove('active'));
					const targetItem = playlistItemsForRestoration.find(i => i.getAttribute('data-url') === savedState.url);
					if (targetItem) {
						targetItem.classList.add('active');
						// Scroll delay nhẹ để đảm bảo DOM đã hiện danh sách
						setTimeout(() => targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' }), 800);
					}
				}
			} catch (e) {
				console.error("Failed to parse saved state", e);
			}
		}

		// Lưu trạng thái phát nhạc định kỳ (2s / lần)
		let lastSaveTime = 0;
		const saveState = () => {
			const activeItem = playlistContainer.querySelector('li.active');
			if (activeItem) {
				const url = activeItem.getAttribute('data-url');
				const title = activeItem.getAttribute('data-title');
				if (url && title) {
					localStorage.setItem('minhhue_radio_state', JSON.stringify({
						url,
						title,
						time: audio.currentTime
					}));
				}
			}
		};

		audio.addEventListener('timeupdate', () => {
			if (Date.now() - lastSaveTime > 2000) {
				saveState();
				lastSaveTime = Date.now();
			}
		});

		// Tự động kiểm tra tham số filter từ URL khi load trang để kích hoạt lọc danh mục
		const urlParams = new URLSearchParams(window.location.search);
		const filterParam = urlParams.get('filter');
		if (filterParam) {
			const targetItem = dropdownItems.find(item => item.getAttribute('data-filter') === filterParam);
			if (targetItem) {
				setTimeout(() => {
					(targetItem as HTMLElement).click();
				}, 150); // Delay nhẹ đảm bảo DOM và Plyr đã sẵn sàng
			}
		}

		let playlistItems = Array.from(playlistContainer.querySelectorAll('li'));
		let visibleItems = [...playlistItems]; // Chứa danh sách các bài phát hiển thị sau lọc
		let isRandomMode = false;

		// 2. Click chọn bài hát
		const attachClickHandlers = () => {
			playlistItems.forEach((item) => {
				item.removeEventListener('click', handleTrackClick);
				item.addEventListener('click', handleTrackClick);
			});
		};

		function handleTrackClick(this: HTMLLIElement) {
			playTrack(this);
		}

		function playTrack(item: HTMLLIElement) {
			const url = item.getAttribute('data-url');
			const title = item.getAttribute('data-title');
			
			if (url && title) {
				audio.src = `/api/audio-proxy?url=${encodeURIComponent(url)}`;
				player.play();
				
				// Cập nhật giao diện active
				playlistItems.forEach(i => i.classList.remove('active'));
				item.classList.add('active');
				
				// Cập nhật tiêu đề bài phát
				currentTrackTitle!.textContent = title;
				
				// Cuộn mượt mà đến bài hát được chọn
				item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			}
		}

		// Khởi động lắng nghe sự kiện lúc đầu
		attachClickHandlers();

		// 3. Xử lý bộ lọc chuyên mục (Dropdown)
		if (categoriesToggle && categoriesDropdown) {
			// Bấm mở/đóng dropdown
			categoriesToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				const isShow = categoriesDropdown.style.display === 'block';
				categoriesDropdown.style.display = isShow ? 'none' : 'block';
				categoriesToggle.classList.toggle('open');
			});

			// Đóng dropdown khi bấm ra ngoài
			document.addEventListener('click', () => {
				categoriesDropdown.style.display = 'none';
				categoriesToggle.classList.remove('open');
			});

			// Lắng nghe chọn chuyên mục
			dropdownItems.forEach((item) => {
				// Ngăn chặn chuyển trang thực tế khi click link để nhạc không bị dừng
				const link = item.querySelector('a');
				if (link) {
					link.addEventListener('click', (e) => {
						e.preventDefault();
					});
				}

				item.addEventListener('click', function(e) {
					e.stopPropagation();
					const filter = item.getAttribute('data-filter');
					const categoryText = item.querySelector('a')?.textContent;

					// Cập nhật lớp active cho nút chọn trong dropdown
					dropdownItems.forEach(i => i.classList.remove('active-category'));
					item.classList.add('active-category');

					// Cập nhật nhãn đã chọn
					if (selectedCategoryText && categoryText) {
						selectedCategoryText.textContent = categoryText;
					}

					// Lọc các li bài phát tương ứng
					playlistItems.forEach((li) => {
						const trackCategory = li.getAttribute('data-category');
						let isMatch = false;

						if (filter === 'all') {
							isMatch = true;
						} else if (filter === 'ngay-phap-luan-dai-phap-the-gioi-radio') {
							// Khớp cả các chuyên mục con theo năm của Ngày Pháp Luân Đại Pháp
							isMatch = trackCategory === filter || (trackCategory && trackCategory.startsWith('ngay-phap-luan-dai-phap-the-gioi'));
						} else if (filter === 'phap-hoi-trung-quoc-radio') {
							// Khớp cả các chuyên mục con theo kỳ của Pháp hội Trung Quốc
							isMatch = trackCategory === filter || (trackCategory && trackCategory.startsWith('phap-hoi-trung-quoc'));
						} else {
							isMatch = trackCategory === filter;
						}

						if (isMatch) {
							li.style.display = 'flex';
						} else {
							li.style.display = 'none';
						}
					});

					// Cập nhật mảng visibleItems dùng cho chuyển bài
					visibleItems = playlistItems.filter(li => li.style.display !== 'none');

					// Hiển thị thông báo rỗng nếu không có bài hát nào thuộc chuyên mục này
					if (emptyPlaylistMsg) {
						if (visibleItems.length === 0) {
							emptyPlaylistMsg.style.display = 'block';
						} else {
							emptyPlaylistMsg.style.display = 'none';
						}
					}

					// Đóng dropdown
					categoriesDropdown.style.display = 'none';
					categoriesToggle.classList.remove('open');
				});
			});
		}

		// 4. Nút đảo thứ tự phát (áp dụng cho visibleItems hiện tại)
		if (revertButton) {
			revertButton.addEventListener('click', () => {
				// Đảo ngược các bài viết hiển thị hiện tại
				visibleItems.reverse();
				// Sắp xếp lại DOM
				playlistContainer.innerHTML = '';
				playlistItems.forEach(item => {
					if (visibleItems.includes(item)) {
						playlistContainer.appendChild(item);
					} else {
						// Giữ các bài bị ẩn vào cuối DOM
						playlistContainer.appendChild(item);
					}
				});
				// Gắn lại sự kiện click
				attachClickHandlers();
				
				// Hiệu ứng tương tác micro-animation
				revertButton.classList.add('action-active');
				setTimeout(() => revertButton.classList.remove('action-active'), 300);
			});
		}

		// 5. Nút phát ngẫu nhiên
		if (randomButton) {
			randomButton.addEventListener('click', () => {
				isRandomMode = !isRandomMode;
				if (isRandomMode) {
					randomButton.classList.add('active-mode');
					if (visibleItems.length > 0) {
						// Chọn ngẫu nhiên bài để phát từ các bài đang hiển thị
						const randomIndex = Math.floor(Math.random() * visibleItems.length);
						playTrack(visibleItems[randomIndex]);
					}
				} else {
					randomButton.classList.remove('active-mode');
				}
			});
		}

		// 6. Tự động chuyển bài khi kết thúc (sử dụng visibleItems hiện có để chuyển đúng bài trong chuyên mục)
		audio.addEventListener('ended', () => {
			if (isRandomMode) {
				if (visibleItems.length > 0) {
					const randomIndex = Math.floor(Math.random() * visibleItems.length);
					playTrack(visibleItems[randomIndex]);
				}
			} else {
				const activeItem = playlistContainer.querySelector('li.active') as HTMLLIElement;
				if (activeItem) {
					const currentVisibleIndex = visibleItems.indexOf(activeItem);
					if (currentVisibleIndex !== -1 && currentVisibleIndex < visibleItems.length - 1) {
						playTrack(visibleItems[currentVisibleIndex + 1]);
					} else if (visibleItems.length > 0) {
						// Nếu là bài cuối của bộ lọc, quay lại bài đầu tiên của bộ lọc
						playTrack(visibleItems[0]);
					}
				}
			}
		});

		// Lắng nghe sự kiện click từ các link menu chuyên mục trên Header để chuyển đổi mượt mà không reload trang (SPA Experience)
		document.querySelectorAll('.dropdown-menu-item').forEach(link => {
			link.addEventListener('click', (e) => {
				const currentPath = window.location.pathname;
				if (currentPath === '/' || currentPath === '' || currentPath === '/index.html') {
					e.preventDefault();
					const url = new URL((link as HTMLAnchorElement).href);
					const filterVal = url.searchParams.get('filter');
					if (filterVal) {
						// Cập nhật URL trình duyệt mượt mà (không reload trang)
						window.history.pushState({}, '', url.pathname + url.search);
						const targetItem = dropdownItems.find(item => item.getAttribute('data-filter') === filterVal);
						if (targetItem) {
							(targetItem as HTMLElement).click();
						}
					}
				}
			});
		});
	});
</script>

