---
// Component Trình phát Radio Minh Huệ siêu cao cấp "Emdash Prime"
import fs from "node:fs";
import path from "node:path";

// Đọc danh sách phát từ file JSON đã cào
const filePath = path.resolve("./radio-playlist.json");
const playlist = fs.existsSync(filePath)
	? JSON.parse(fs.readFileSync(filePath, "utf-8"))
	: [];

// Bài hát đầu tiên làm mặc định
const defaultTrack = playlist.length > 0 ? playlist[0] : {
	title: "Phát thanh Minh Huệ: Trừ bỏ chấp trước vào điện thoại – Tìm về trạng thái tu luyện như thuở đầu (Số 3)",
	url: "https://vi.minghui.org/radio/20250926-TDTH.mp3",
	category: "tru-bo-chap-truoc-vao-dien-thoai"
};
---

<div class="emdash-radio-layout-container">
	{/* Khối bên trái: Trình phát nhạc chính */}
	<div class="emdash-player-card-premium">
		{/* Hiệu ứng phát quang nhẹ ở viền thẻ */}
		<div class="radio-glow-border"></div>

		<div class="radio-left-panel-premium">
			{/* Tiêu đề & Trạng thái phát */}
			<header class="radio-header">
				<div class="radio-live-tag">
					<span class="live-pulse"></span>
					RADIO
				</div>
				<h3 class="radio-main-title">Phát Thanh Minh Huệ</h3>
			</header>

			{/* Giao diện bài đang phát hiện tại */}
			<div class="now-playing-box">
				<span class="now-playing-label">Đang phát:</span>
				<h4 id="current-track-title" class="current-track-title">
					{defaultTrack.title}
				</h4>
			</div>

			{/* Trình phát Audio tùy chỉnh siêu tối giản */}
			<div class="custom-player-premium">
				<audio id="audio-player" preload="metadata">
					<source src={`/api/audio-proxy?url=${encodeURIComponent(defaultTrack.url)}`} type="audio/mpeg" />
					Trình duyệt của bạn không hỗ trợ phát âm thanh trực tiếp.
				</audio>

				{/* 1. Thanh Tiến Trình (Progress Slider) */}
				<div class="custom-progress-area">
					<input type="range" id="custom-seek-slider" class="custom-seek-slider" min="0" max="100" value="0" step="0.1" />
					<div class="custom-time-display">
						<span id="custom-time-current">00:00</span>
						<span id="custom-time-duration">00:00</span>
					</div>
				</div>

				{/* 2. Hàng điều khiển tối giản (Controls) */}
				<div class="custom-controls-row">
					{/* Điều chỉnh tốc độ */}
					<button id="custom-speed-btn" class="custom-player-btn speed-btn" title="Tốc độ phát">
						1.0x
					</button>

					<div class="custom-center-controls">
						{/* Tua lùi 10s */}
						<button id="custom-rewind-btn" class="custom-player-btn control-secondary-btn" title="Lùi 10 giây">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 14 12 10 16 6"/><path d="M12 14 8 10 12 6"/><path d="M20 18a8 8 0 1 0-8 8h1"/></svg>
						</button>

						{/* Nút Play/Pause chính */}
						<button id="custom-play-btn" class="custom-play-main-btn" title="Phát / Tạm dừng">
							<svg id="play-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
							<svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="display:none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
						</button>

						{/* Tua đi 30s */}
						<button id="custom-forward-btn" class="custom-player-btn control-secondary-btn" title="Tiến 30 giây">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6l4 4-4 4"/><path d="M12 6l4 4-4 4"/><path d="M4 18a8 8 0 1 1 8 8h-1"/></svg>
						</button>
					</div>

					{/* Chỉ báo trạng thái thiền định */}
					<div class="custom-status-indicator">
						<span id="player-status-dot" class="status-dot"></span>
						<span id="player-status-text" class="status-text">Đang dừng</span>
					</div>
				</div>
			</div>
		</div>
	</div>

	{/* Khối bên phải: Danh sách phát */}
	<div class="emdash-playlist-card-premium">
		{/* Hiệu ứng phát quang nhẹ ở viền thẻ */}
		<div class="radio-glow-border"></div>

		<div class="radio-right-panel-premium">
			<div class="playlist-section">
				<div class="playlist-header">
					<h4 class="playlist-title">Danh Sách Phát Mới Nhất</h4>
					<div class="playlist-actions">
						<button id="random-playlist" class="action-btn" title="Phát ngẫu nhiên">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 17h10"/><path d="M7 12h10"/><path d="M7 7h10"/></svg>
							Ngẫu nhiên
						</button>
						<button id="revert-playlist" class="action-btn" title="Đảo thứ tự bài">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 16 4 4 4-4"/><path d="M7 20V4"/><path d="m21 8-4-4-4 4"/><path d="M17 4v16"/></svg>
							Đảo thứ tự
						</button>
					</div>
				</div>

				<!-- Thẻ nhúng danh mục đồng bộ chuẩn 100% giao thức Minh Huệ Net -->
				<div class="categories-filter-wrapper">
					<div class="sub-categories-nav-toggle" id="categories-toggle">
						<span id="selected-category-text">Danh sách chuyên mục</span>
						<i class="sub-categories-nav-icon"></i>
					</div>
					
					<div class="sub-categories-nav-items" id="categories-dropdown" style="display: none;">
						<ul>
							<li class="sub-category-nav-item active-category" data-filter="all">
								<div>
									<a href="#">Tất cả phát thanh</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tru-bo-chap-truoc-vao-dien-thoai">
								<div>
									<a href="/news/category/tru-bo-chap-truoc-vao-dien-thoai">Trừ bỏ chấp trước vào điện thoại</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="ngay-phap-luan-dai-phap-the-gioi-radio">
								<div>
									<a href="/news/category/ngay-phap-luan-dai-phap-the-gioi-radio">Ngày Pháp Luân Đại Pháp Thế giới</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="phap-hoi-trung-quoc-radio">
								<div>
									<a href="/news/category/phap-hoi-trung-quoc-radio">Pháp hội Trung Quốc</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tin-tuc-tai-dai-luc">
								<div>
									<a href="/news/category/tin-tuc-tai-dai-luc">Tin tức tại Đại Lục</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tin-tuc-tren-the-gioi">
								<div>
									<a href="/news/category/tin-tuc-tren-the-gioi">Tin tức trên thế giới</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="thien-am-tinh-nhac">
								<div>
									<a href="/news/category/thien-am-tinh-nhac">Thiên Âm Tịnh Nhạc</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="kien-tri-hoc-thuoc-phap">
								<div>
									<a href="/news/category/kien-tri-hoc-thuoc-phap">Kiên trì học thuộc Pháp</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tin-tuc-tong-hop">
								<div>
									<a href="/news/category/tin-tuc">Tin tức tổng hợp</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="cau-chuyen-tu-luyen">
								<div>
									<a href="/news/category/cau-chuyen-tu-luyen">Câu chuyện tu luyện</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="giai-the-van-hoa-dang">
								<div>
									<a href="/news/category/giai-the-van-hoa-dang">Giải thể văn hóa đảng</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="radio-hoi-uc-ve-su-phu">
								<div>
									<a href="/news/category/radio-hoi-uc-ve-su-phu">Hồi ức về Sư Phụ</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tuyen-tap-bai-chia-se-cua-tieu-de-tu-dai-phap">
								<div>
									<a href="/news/category/tuyen-tap-bai-chia-se-cua-tieu-de-tu-dai-phap">Tiểu đệ tử Đại Pháp</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tuyen-tap-cac-bai-chia-se-cua-de-tu-dai-phap-tre-tuoi">
								<div>
									<a href="/news/category/tuyen-tap-cac-bai-chia-se-cua-de-tu-dai-phap-tre-tuoi">Đệ tử Đại Pháp trẻ tuổi</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="tuyen-tap-cac-bai-chia-se-tu-luyen-chinh-phap">
								<div>
									<a href="/news/category/tuyen-tap-cac-bai-chia-se-tu-luyen-chinh-phap">Tu luyện Chính Pháp</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="dot-pha-gia-tuong-nghiep-benh">
								<div>
									<a href="/news/category/dot-pha-gia-tuong-nghiep-benh">Đột phá giả tướng nghiệp bệnh</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="mot-niem-giua-thien-va-ac">
								<div>
									<a href="/news/category/mot-niem-giua-thien-va-ac">Một niệm giữa thiện và ác</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="cuoc-song-va-hy-vong-da-quay-tro-lai">
								<div>
									<a href="/news/category/cuoc-song-va-hy-vong-da-quay-tro-lai">Cuộc sống và hy vọng đã quay trở lại</a>
								</div>
							</li>
							<li class="sub-category-nav-item" data-filter="bai-chia-se-co-loi-binh-cua-su-phu">
								<div>
									<a href="/news/category/bai-chia-se-co-loi-binh-cua-su-phu">Bài chia sẻ có lời bình của Sư phụ</a>
								</div>
							</li>
						</ul>
					</div>
				</div>
 
				<div class="playlist-scroll-container">
					<!-- Thông báo nếu không có phát thanh trong mục chọn -->
					<p id="empty-playlist-msg" class="empty-playlist-msg">
						Không có phát thanh nào thuộc chuyên mục này.
					</p>
 
					<ul id="playlist">
						{playlist.map((track, index) => {
							// Định dạng số thứ tự dạng hai chữ số (01, 02...)
							const trackNum = String(index + 1).padStart(2, '0');
							// Rút gọn tiêu đề hiển thị trong danh sách phát cho gọn gàng và đẹp
							let displayName = track.title;
							displayName = displayName.replace(/\[\d{2}-\d{2}-\d{4}\]/g, ''); // Xóa [DD-MM-YYYY]
							displayName = displayName.replace(/Phát thanh Minh Huệ:\s*/g, '');
							displayName = displayName.replace(/Phát thanh Minh Huệ\s*\(.*?\):\s*/g, '');
							displayName = displayName.trim();
 
							return (
								<li 
									data-url={track.url} 
									data-title={track.title} 
									data-category={track.category} 
									class={index === 0 ? "active" : ""}
								>
									<span class="track-number">{trackNum}</span>
									<span class="track-name" title={track.title}>{displayName}</span>
								</li>
							);
						})}
					</ul>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const audio = document.getElementById('audio-player') as HTMLAudioElement;
		const currentTrackTitle = document.getElementById('current-track-title');
		const playlistContainer = document.getElementById('playlist');
		const revertButton = document.getElementById('revert-playlist');
		const randomButton = document.getElementById('random-playlist');
		
		// Selector cho bộ lọc chuyên mục
		const categoriesToggle = document.getElementById('categories-toggle');
		const categoriesDropdown = document.getElementById('categories-dropdown');
		const selectedCategoryText = document.getElementById('selected-category-text');
		const emptyPlaylistMsg = document.getElementById('empty-playlist-msg');
		const dropdownItems = categoriesDropdown ? Array.from(categoriesDropdown.querySelectorAll('.sub-category-nav-item')) : [];

		// Custom Player Controls
		const playBtn = document.getElementById('custom-play-btn');
		const playIcon = document.getElementById('play-icon');
		const pauseIcon = document.getElementById('pause-icon');
		const seekSlider = document.getElementById('custom-seek-slider') as HTMLInputElement;
		const timeCurrent = document.getElementById('custom-time-current');
		const timeDuration = document.getElementById('custom-time-duration');
		const speedBtn = document.getElementById('custom-speed-btn');
		const rewindBtn = document.getElementById('custom-rewind-btn');
		const forwardBtn = document.getElementById('custom-forward-btn');
		const statusDot = document.getElementById('player-status-dot');
		const statusText = document.getElementById('player-status-text');

		if (!audio || !currentTrackTitle || !playlistContainer) return;

		// Hỗ trợ tốc độ phát
		const speeds = [1.0, 1.25, 1.5, 2.0, 0.75];
		let currentSpeedIndex = 0;

		if (speedBtn) {
			speedBtn.addEventListener('click', () => {
				currentSpeedIndex = (currentSpeedIndex + 1) % speeds.length;
				const newSpeed = speeds[currentSpeedIndex];
				audio.playbackRate = newSpeed;
				speedBtn.textContent = `${newSpeed.toFixed(2).replace('.00', '')}x`;
			});
		}

		// Tua lùi 10s và tua đi 30s
		if (rewindBtn) {
			rewindBtn.addEventListener('click', () => {
				audio.currentTime = Math.max(0, audio.currentTime - 10);
			});
		}
		if (forwardBtn) {
			forwardBtn.addEventListener('click', () => {
				audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 30);
			});
		}

		// Hàm định dạng thời gian (mm:ss)
		const formatTime = (secs: number) => {
			if (isNaN(secs)) return "00:00";
			const minutes = Math.floor(secs / 60);
			const seconds = Math.floor(secs % 60);
			return `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
		};

		// Cập nhật trạng thái giao diện phát/tạm dừng
		const updatePlayState = (isPlaying: boolean) => {
			if (!playIcon || !pauseIcon || !statusDot || !statusText) return;
			if (isPlaying) {
				playIcon.style.display = 'none';
				pauseIcon.style.display = 'block';
				statusDot.classList.add('playing');
				statusText.textContent = 'Đang phát';
				playBtn?.classList.add('playing');
			} else {
				playIcon.style.display = 'block';
				pauseIcon.style.display = 'none';
				statusDot.classList.remove('playing');
				statusText.textContent = 'Đang dừng';
				playBtn?.classList.remove('playing');
			}
		};

		// Play / Pause toggle
		if (playBtn) {
			playBtn.addEventListener('click', () => {
				if (audio.paused) {
					audio.play().catch(err => console.log("Playback error", err));
				} else {
					audio.pause();
				}
			});
		}

		audio.addEventListener('play', () => updatePlayState(true));
		audio.addEventListener('pause', () => updatePlayState(false));

		// Đồng bộ tiến trình thời gian
		audio.addEventListener('timeupdate', () => {
			if (seekSlider && !isDraggingSlider) {
				const duration = audio.duration || 0;
				const currentTime = audio.currentTime || 0;
				seekSlider.value = duration > 0 ? String((currentTime / duration) * 100) : "0";
				
				// Đổi màu nền background cho input range để tạo track fill tự nhiên
				const percent = duration > 0 ? (currentTime / duration) * 100 : 0;
				seekSlider.style.background = `linear-gradient(to right, var(--color-accent) ${percent}%, var(--color-border) ${percent}%)`;
			}
			if (timeCurrent) {
				timeCurrent.textContent = formatTime(audio.currentTime);
			}
		});

		// Khi load xong metadata
		audio.addEventListener('loadedmetadata', () => {
			if (timeDuration) {
				timeDuration.textContent = formatTime(audio.duration);
			}
			if (seekSlider) {
				seekSlider.style.background = `linear-gradient(to right, var(--color-accent) 0%, var(--color-border) 0%)`;
			}
		});

		// Kéo thanh trượt
		let isDraggingSlider = false;
		if (seekSlider) {
			seekSlider.addEventListener('input', () => {
				isDraggingSlider = true;
				if (timeCurrent) {
					const duration = audio.duration || 0;
					const targetTime = (parseFloat(seekSlider.value) / 100) * duration;
					timeCurrent.textContent = formatTime(targetTime);
				}
			});

			seekSlider.addEventListener('change', () => {
				isDraggingSlider = false;
				const duration = audio.duration || 0;
				audio.currentTime = (parseFloat(seekSlider.value) / 100) * duration;
			});
		}

		// Khôi phục trạng thái phát nhạc từ localStorage
		const savedStateStr = localStorage.getItem('minhhue_radio_state');
		if (savedStateStr) {
			try {
				const savedState = JSON.parse(savedStateStr);
				if (savedState.url && savedState.title) {
					audio.src = `/api/audio-proxy?url=${encodeURIComponent(savedState.url)}`;
					currentTrackTitle.textContent = savedState.title;
					
					// Đặt lại tốc độ hiện tại nếu có lưu
					audio.playbackRate = speeds[currentSpeedIndex];
					
					const setSavedTime = () => {
						if (savedState.time) {
							audio.currentTime = savedState.time;
						}
						if (timeDuration) {
							timeDuration.textContent = formatTime(audio.duration);
						}
						audio.removeEventListener('loadedmetadata', setSavedTime);
					};
					audio.addEventListener('loadedmetadata', setSavedTime);

					// Đánh dấu active trên danh sách
					const playlistItemsForRestoration = Array.from(playlistContainer.querySelectorAll('li'));
					playlistItemsForRestoration.forEach(i => i.classList.remove('active'));
					const targetItem = playlistItemsForRestoration.find(i => i.getAttribute('data-url') === savedState.url);
					if (targetItem) {
						targetItem.classList.add('active');
						setTimeout(() => targetItem.scrollIntoView({ behavior: 'smooth', block: 'center' }), 800);
					}
				}
			} catch (e) {
				console.error("Failed to parse saved state", e);
			}
		}

		// Lưu trạng thái phát nhạc định kỳ (2s / lần)
		let lastSaveTime = 0;
		const saveState = () => {
			const activeItem = playlistContainer.querySelector('li.active');
			if (activeItem) {
				const url = activeItem.getAttribute('data-url');
				const title = activeItem.getAttribute('data-title');
				if (url && title) {
					localStorage.setItem('minhhue_radio_state', JSON.stringify({
						url,
						title,
						time: audio.currentTime
					}));
				}
			}
		};

		audio.addEventListener('timeupdate', () => {
			if (Date.now() - lastSaveTime > 2000) {
				saveState();
				lastSaveTime = Date.now();
			}
		});

		// Tự động kiểm tra tham số filter từ URL khi load trang để kích hoạt lọc danh mục
		const urlParams = new URLSearchParams(window.location.search);
		const filterParam = urlParams.get('filter');
		if (filterParam) {
			const targetItem = dropdownItems.find(item => item.getAttribute('data-filter') === filterParam);
			if (targetItem) {
				setTimeout(() => {
					(targetItem as HTMLElement).click();
				}, 150);
			}
		}

		let playlistItems = Array.from(playlistContainer.querySelectorAll('li'));
		let visibleItems = [...playlistItems];
		let isRandomMode = false;

		const attachClickHandlers = () => {
			playlistItems.forEach((item) => {
				item.removeEventListener('click', handleTrackClick);
				item.addEventListener('click', handleTrackClick);
			});
		};

		function handleTrackClick(this: HTMLLIElement) {
			playTrack(this);
		}

		function playTrack(item: HTMLLIElement) {
			const url = item.getAttribute('data-url');
			const title = item.getAttribute('data-title');
			
			if (url && title) {
				audio.src = `/api/audio-proxy?url=${encodeURIComponent(url)}`;
				audio.playbackRate = speeds[currentSpeedIndex]; // Duy trì tốc độ phát đã chọn
				audio.play().catch(err => console.log("Playback error", err));
				
				playlistItems.forEach(i => i.classList.remove('active'));
				item.classList.add('active');
				
				currentTrackTitle!.textContent = title;
				item.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
			}
		}

		attachClickHandlers();

		// Xử lý bộ lọc chuyên mục (Dropdown)
		if (categoriesToggle && categoriesDropdown) {
			categoriesToggle.addEventListener('click', (e) => {
				e.stopPropagation();
				const isShow = categoriesDropdown.style.display === 'block';
				categoriesDropdown.style.display = isShow ? 'none' : 'block';
				categoriesToggle.classList.toggle('open');
			});

			document.addEventListener('click', () => {
				categoriesDropdown.style.display = 'none';
				categoriesToggle.classList.remove('open');
			});

			dropdownItems.forEach((item) => {
				const link = item.querySelector('a');
				if (link) {
					link.addEventListener('click', (e) => {
						e.preventDefault();
					});
				}

				item.addEventListener('click', function(e) {
					e.stopPropagation();
					const filter = item.getAttribute('data-filter');
					const categoryText = item.querySelector('a')?.textContent;

					dropdownItems.forEach(i => i.classList.remove('active-category'));
					item.classList.add('active-category');

					if (selectedCategoryText && categoryText) {
						selectedCategoryText.textContent = categoryText;
					}

					playlistItems.forEach((li) => {
						const trackCategory = li.getAttribute('data-category');
						let isMatch = false;

						if (filter === 'all') {
							isMatch = true;
						} else if (filter === 'ngay-phap-luan-dai-phap-the-gioi-radio') {
							isMatch = trackCategory === filter || (trackCategory && trackCategory.startsWith('ngay-phap-luan-dai-phap-the-gioi'));
						} else if (filter === 'phap-hoi-trung-quoc-radio') {
							isMatch = trackCategory === filter || (trackCategory && trackCategory.startsWith('phap-hoi-trung-quoc'));
						} else {
							isMatch = trackCategory === filter;
						}

						if (isMatch) {
							li.style.display = 'flex';
						} else {
							li.style.display = 'none';
						}
					});

					visibleItems = playlistItems.filter(li => li.style.display !== 'none');

					if (emptyPlaylistMsg) {
						if (visibleItems.length === 0) {
							emptyPlaylistMsg.style.display = 'block';
						} else {
							emptyPlaylistMsg.style.display = 'none';
						}
					}

					categoriesDropdown.style.display = 'none';
					categoriesToggle.classList.remove('open');
				});
			});
		}

		// Nút đảo thứ tự phát
		if (revertButton) {
			revertButton.addEventListener('click', () => {
				visibleItems.reverse();
				playlistContainer.innerHTML = '';
				playlistItems.forEach(item => {
					if (visibleItems.includes(item)) {
						playlistContainer.appendChild(item);
					} else {
						playlistContainer.appendChild(item);
					}
				});
				attachClickHandlers();
				revertButton.classList.add('action-active');
				setTimeout(() => revertButton.classList.remove('action-active'), 300);
			});
		}

		// Nút phát ngẫu nhiên
		if (randomButton) {
			randomButton.addEventListener('click', () => {
				isRandomMode = !isRandomMode;
				if (isRandomMode) {
					randomButton.classList.add('active-mode');
					if (visibleItems.length > 0) {
						const randomIndex = Math.floor(Math.random() * visibleItems.length);
						playTrack(visibleItems[randomIndex]);
					}
				} else {
					randomButton.classList.remove('active-mode');
				}
			});
		}

		// Tự động chuyển bài khi kết thúc
		audio.addEventListener('ended', () => {
			if (isRandomMode) {
				if (visibleItems.length > 0) {
					const randomIndex = Math.floor(Math.random() * visibleItems.length);
					playTrack(visibleItems[randomIndex]);
				}
			} else {
				const activeItem = playlistContainer.querySelector('li.active') as HTMLLIElement;
				if (activeItem) {
					const currentVisibleIndex = visibleItems.indexOf(activeItem);
					if (currentVisibleIndex !== -1 && currentVisibleIndex < visibleItems.length - 1) {
						playTrack(visibleItems[currentVisibleIndex + 1]);
					} else if (visibleItems.length > 0) {
						playTrack(visibleItems[0]);
					}
				}
			}
		});

		// Lắng nghe sự kiện click từ các link menu chuyên mục trên Header
		document.querySelectorAll('.dropdown-menu-item').forEach(link => {
			link.addEventListener('click', (e) => {
				const currentPath = window.location.pathname;
				if (currentPath === '/' || currentPath === '' || currentPath === '/index.html') {
					e.preventDefault();
					const url = new URL((link as HTMLAnchorElement).href);
					const filterVal = url.searchParams.get('filter');
					if (filterVal) {
						window.history.pushState({}, '', url.pathname + url.search);
						const targetItem = dropdownItems.find(item => item.getAttribute('data-filter') === filterVal);
						if (targetItem) {
							(targetItem as HTMLElement).click();
						}
					}
				}
			});
		});
	});
</script>
