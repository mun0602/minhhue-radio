---
import Base from "../layouts/Base.astro";
import RadioPlayer from "../components/RadioPlayer.astro";

const siteTitle = "Phát Thanh Minh Huệ";
const siteTagline = "Trang phát thanh chia sẻ trải nghiệm tu luyện và tin tức Pháp Luân Đại Pháp trên toàn thế giới";
---

<Base title={siteTitle} description={siteTagline}>
	<div class="home-content-premium">
		{/* Hiệu ứng Quả cầu ánh sáng nền Light Mode cát tường */}
		<div class="glow-orb orb-1"></div>
		<div class="glow-orb orb-2"></div>

		{/* Trình phát Radio nổi bật làm trung tâm duy nhất */}
		<section class="radio-hero-section-premium">
			<RadioPlayer />
		</section>
	</div>
</Base>

<style>
	.home-content-premium {
		font-family: var(--font-sans);
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6) var(--spacing-24);
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-height: calc(100vh - var(--nav-height) - 250px);
		position: relative;
		overflow: hidden;
	}

	/* Tối ưu hóa mobile: Tự động giãn chiều cao theo nội dung giúp cuộn trang phóng khoáng, tự nhiên */
	@media (max-width: 600px) {
		.home-content-premium {
			padding: var(--spacing-12) var(--spacing-4) var(--spacing-12);
			min-height: auto;
		}
		.radio-hero-section-premium {
			display: flex;
			flex-direction: column;
		}
		/* Hide heavy blur(120px) orbs on mobile — devastating for iOS Safari GPU */
		.glow-orb {
			display: none !important;
		}
	}

	/* ============================================================================
	   Hiệu Ứng Quả Cầu Ánh Sáng Nền Light Mode cát tường
	   ============================================================================ */
	.glow-orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.12;
		z-index: -1;
		pointer-events: none;
		animation: orbMovement 20s infinite alternate ease-in-out;
	}

	.orb-1 {
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, rgba(0, 124, 240, 0.18), rgba(0, 223, 216, 0.12));
		top: -100px;
		right: -100px;
		animation-delay: 0s;
	}

	.orb-2 {
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(0, 223, 216, 0.18), rgba(245, 158, 11, 0.08));
		bottom: -150px;
		left: -200px;
		animation-delay: -5s;
	}

	@keyframes orbMovement {
		0% {
			transform: translate(0, 0) scale(1);
		}
		50% {
			transform: translate(40px, -40px) scale(1.08);
		}
		100% {
			transform: translate(-20px, 20px) scale(0.92);
		}
	}

	/* Hide glow orbs on mobile — blur(120px) + infinite animation kills performance */
	@media (max-width: 768px) {
		.glow-orb {
			display: none !important;
		}
	}

	.radio-hero-section-premium {
		width: 100%;
		animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
